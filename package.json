{
  "name": "city-data-mcp",
  "version": "0.2.0",
  "description": "MCP server for US civic data — demographics, economics, crime, employment across 30 cities. Includes peer city cohort builder.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "city-data-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "start:api": "NODE_TLS_REJECT_UNAUTHORIZED=0 node dist/api.js"
  },
  "keywords": [
    "mcp",
    "claude",
    "open-data",
    "city-data",
    "socrata",
    "census",
    "fred",
    "crime",
    "government",
    "civic-data",
    "demographics"
  ],
  "author": "Noa Reikhav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noareikhav/city-data-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist",
    "data"
  ]
}
